# 네이버 검색 API (https://developers.naver.com → 애플리케이션 등록 → 검색 API 선택)
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# 네이버 블로그 API (위와 동일한 앱에서 블로그 권한 추가, 또는 별도 앱 등록)
NAVER_BLOG_CLIENT_ID=your_naver_blog_client_id
NAVER_BLOG_CLIENT_SECRET=your_naver_blog_client_secret

# Gemini API (https://aistudio.google.com/app/apikey 에서 무료 발급)
GEMINI_API_KEY=your_gemini_api_key
